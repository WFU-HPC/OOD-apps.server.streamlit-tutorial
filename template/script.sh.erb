#!/usr/bin/env bash

# make sure module command is available //want to make a module for it
. /usr/share/Modules/init/bash

echo "Starting main script..."
echo "TTT - $(date)"

set -x

# activate the environment
module load envs/streamlit

# launch Streamlit
streamlit run ./app.py --logger.level="debug"

echo "TTT - $(date)"
